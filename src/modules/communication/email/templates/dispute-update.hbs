<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dispute Update</title>
  <style>
    body { margin: 0; padding: 0; background-color: #f5f5f5; font-family: 'Plus Jakarta Sans', Arial, sans-serif; }
    .wrapper { max-width: 600px; margin: 40px auto; background: #ffffff; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .header { background-color: #2E7D32; padding: 40px 32px; text-align: center; }
    .header h1 { color: #FDC500; font-size: 36px; font-weight: 700; margin: 0; letter-spacing: -1px; }
    .header p { color: #ffffff; margin: 8px 0 0; font-size: 14px; opacity: 0.9; }
    .body { padding: 40px 32px; }
    .body h2 { color: #151515; font-size: 22px; font-weight: 700; margin: 0 0 8px; }
    .body p { color: #555555; font-size: 15px; line-height: 1.6; margin: 0 0 16px; }
    .status-badge { display: inline-block; padding: 8px 20px; border-radius: 20px; font-weight: 700; font-size: 14px; margin: 8px 0 16px; background-color: #e8f5e9; color: #2E7D32; }
    .resolution-box { background-color: #f9f9f9; border-radius: 8px; padding: 20px; margin: 20px 0; }
    .resolution-box h3 { color: #151515; font-size: 15px; font-weight: 700; margin: 0 0 8px; }
    .resolution-box p { color: #555555; font-size: 14px; margin: 0; }
    .btn { display: inline-block; background-color: #2E7D32; color: #ffffff; text-decoration: none; padding: 14px 32px; border-radius: 8px; font-weight: 600; font-size: 15px; margin: 16px 0 24px; }
    .footer { background-color: #f9f9f9; padding: 24px 32px; text-align: center; }
    .footer p { color: #9b9b9b; font-size: 12px; margin: 0; line-height: 1.6; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <h1>Shopa</h1>
      <p>Dispute Update</p>
    </div>
    <div class="body">
      <h2>Your dispute has been updated</h2>
      <div class="status-badge">{{status}}</div>
      {{#if resolution}}
      <div class="resolution-box">
        <h3>Resolution</h3>
        <p>{{resolution}}</p>
      </div>
      {{/if}}
      <p>If you have any questions about this decision, please contact support.</p>
      <a href="{{frontendUrl}}/orders" class="btn">View Orders</a>
    </div>
    <div class="footer">
      <p>© {{year}} Shopa. All rights reserved.<br/>Crawford University Campus Marketplace</p>
    </div>
  </div>
</body>
</html>
