<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; }
    .header { background: #4F46E5; color: white; padding: 20px; text-align: center; }
    .content { padding: 20px; }
    .box { background: #f4f4f5; padding: 16px; border-radius: 8px; margin: 16px 0; }
    .footer { padding: 20px; color: #666; font-size: 12px; text-align: center; }
  </style>
</head>
<body>
  <div class="header">
    <h1>Order Update</h1>
  </div>
  <div class="content">
    <p>Order <strong>{{orderNumber}}</strong></p>
    <div class="box">
      <p><strong>Status:</strong> {{status}}</p>
      <p>{{statusMessage}}</p>
    </div>
  </div>
  <div class="footer">
    <p>© {{year}} Shopa. All rights reserved.</p>
  </div>
</body>
</html>
